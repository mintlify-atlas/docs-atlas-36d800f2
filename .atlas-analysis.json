  "keyFeatures": [
    "Spatial data types (Point, LineString, Polygon, MultiPoint, MultiLineString, MultiPolygon, GeometryCollection)",
    "Eloquent model integration with automatic casting",
    "Spatial query scopes (distance, within, contains, intersects, touches, crosses, etc.)",
    "Multiple format support (WKT, WKB, GeoJSON)",
    "SRID support for coordinate systems",
    "Multi-database support (MySQL 5.7/8, MariaDB 10, PostgreSQL 12-16 with PostGIS)",
    "Custom geometry class extensions",
    "Macroable geometry classes",
    "HasSpatial trait for spatial query capabilities"
